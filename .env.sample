# Get BOT_TOKEN from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Get API_ID and API_HASH from https://my.telegram.org
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Your Telegram user ID (comma separated for multiple admins)
ADMINS=your_user_id_here

# Log channel ID (bot will send startup message here)
LOG_CHANNEL=your_log_channel_id_here

# Google Drive upload (for files > 2GB)
# Path to your service account JSON key file
GDRIVE_SA_FILE=service_account.json
# Google Drive folder ID where encoded videos will be uploaded
GDRIVE_FOLDER_ID=your_folder_id_here
