{
  "name": "Video Encoder Bot",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers-extra/features/apt-packages:1": {
      "packages": "ffmpeg"
    }
  },
  "onCreateCommand": "chmod +x .devcontainer/*.sh && python3 -m venv /workspaces/video-encoder-bot/venv && /workspaces/video-encoder-bot/venv/bin/python3 -m pip install --no-cache-dir -r requirements.txt",
  "postStartCommand": "bash /workspaces/video-encoder-bot/.devcontainer/auto-run.sh &",
  "postAttachCommand": "bash /workspaces/video-encoder-bot/.devcontainer/auto-run.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "./venv/bin/python3"
      },
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
